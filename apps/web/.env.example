# Atlas Command Web — Environment Variables
# Copy to .env.local and fill in values

# Database (for Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atlas_command?schema=public"

# Anthropic AI (for Atlas Commander chat via /api/chat route)
ANTHROPIC_API_KEY=""

# FastAPI Backend URL
NEXT_PUBLIC_API_URL="http://localhost:8000"

# MapLibre — free dark tiles, no key needed
NEXT_PUBLIC_MAP_STYLE="https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json"
