# Atlas Command Web — Environment Variables
# Copy to .env.local and fill in values

# Database (for Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atlas_command?schema=public"

# Anthropic AI (for Atlas Commander chat via /api/chat route)
ANTHROPIC_API_KEY=""

# Redis
REDIS_URL=""

# FastAPI Backend URL
NEXT_PUBLIC_API_URL="http://localhost:8000"

# MapLibre — free dark tiles, no key needed
NEXT_PUBLIC_MAPLIBRE_STYLE="https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json"

# Twilio (WhatsApp notifications)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""
